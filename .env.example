# =========================
# Local development example
# =========================
# Copy this file to .env and adjust values for your machine.

# Database
DATABASE_URL=sqlite:///messenger.db
# Production example:
# DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/sec_messenger
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=true

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=supersecret
MINIO_BUCKET=media
MINIO_SECURE=false
MINIO_CONNECT_TIMEOUT=5
MINIO_READ_TIMEOUT=20
MINIO_OPERATION_TIMEOUT=8
MINIO_HTTP_POOL_MAXSIZE=32
MINIO_USE_VIRTUAL_STYLE=false
APP_PUBLIC_BASE_URL=http://127.0.0.1:5000

# If true, message/post uploads fall back to local static storage when MinIO is down.
MEDIA_LOCAL_FALLBACK_ENABLED=true

# CORS / Socket.IO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# "inherit" uses CORS_ALLOWED_ORIGINS, "reverse_proxy" disables direct Socket.IO CORS.
SOCKETIO_CORS_ALLOWED_ORIGINS=inherit
SOCKETIO_MESSAGE_QUEUE=
SOCKETIO_PING_TIMEOUT=25
SOCKETIO_PING_INTERVAL=20
SOCKETIO_LOGGER=false
SOCKETIO_ENGINEIO_LOGGER=false

# Async task queue (worker-backed side effects)
ASYNC_TASKS_ENABLED=false
ASYNC_TASK_QUEUE_NAME=sec_message:async_tasks
ASYNC_TASK_WORKER_BLOCK_TIMEOUT_SECONDS=5
ASYNC_TASK_MAX_RETRIES=2
ASYNC_TASK_INLINE_FALLBACK=true
ASYNC_TASK_ENQUEUE_SOCKET_TIMEOUT_SECONDS=0.75
ASYNC_TASK_ENQUEUE_CONNECT_TIMEOUT_SECONDS=0.75

# Local HTTP cookies (for HTTPS production keep these as None/true)
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=false

# Messaging attachments
MESSAGE_ATTACHMENT_MAX_SIZE_BYTES=26214400

# Optional media/profile tuning
MEDIA_CACHE_MAX_AGE_SECONDS=604800
MEDIA_CACHE_IMMUTABLE=true
MEDIA_STREAM_CHUNK_SIZE=262144
PROFILE_VIDEO_MAX_DURATION_SECONDS=5
PROFILE_VIDEO_MAX_SIZE_BYTES=15728640

# Moderation cleanup worker
MODERATION_CLEANUP_BACKGROUND_ENABLED=true
MODERATION_CLEANUP_INTERVAL_SECONDS=300
