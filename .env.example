# =========================
# Local development example
# =========================
# Copy this file to .env and adjust values for your machine.

# Database
APP_ENV=development
DATABASE_URL=sqlite:///messenger.db
# Production example:
# DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/sec_messenger
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTH_PASSWORD_PEPPER=CHANGE_ME_TO_A_LONG_RANDOM_PEPPER
AUTH_PASSWORD_MIN_LENGTH=6
AUTH_PASSWORD_MAX_LENGTH=128
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_KEY_PREFIX=auth:login_rl
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_MEMORY_COST_KIB=65536
AUTH_ARGON2_PARALLELISM=4
AUTH_ARGON2_HASH_LEN=32
AUTH_ARGON2_SALT_LEN=16
AUTH_PASSWORD_MIGRATION_ENABLED=true
AUTH_PASSWORD_MIGRATION_BATCH_SIZE=1000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=true

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=supersecret
MINIO_BUCKET=media
MINIO_SECURE=false
MINIO_CONNECT_TIMEOUT=5
MINIO_READ_TIMEOUT=20
MINIO_OPERATION_TIMEOUT=8
MINIO_HTTP_POOL_MAXSIZE=32
MINIO_USE_VIRTUAL_STYLE=false
APP_PUBLIC_BASE_URL=http://127.0.0.1:5000

# If true, message/post uploads fall back to local static storage when MinIO is down.
MEDIA_LOCAL_FALLBACK_ENABLED=true

# CORS / Socket.IO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# "inherit" uses CORS_ALLOWED_ORIGINS, "reverse_proxy" disables direct Socket.IO CORS.
SOCKETIO_CORS_ALLOWED_ORIGINS=inherit
SOCKETIO_MESSAGE_QUEUE=
SOCKETIO_PING_TIMEOUT=25
SOCKETIO_PING_INTERVAL=20
SOCKETIO_LOGGER=false
SOCKETIO_ENGINEIO_LOGGER=false
PRESENCE_CONNECTION_TTL_SECONDS=75
PRESENCE_HEARTBEAT_INTERVAL_SECONDS=20
PRESENCE_CLEANUP_BATCH_SIZE=200

# Async task queue (worker-backed side effects)
ASYNC_TASKS_ENABLED=false
ASYNC_TASK_QUEUE_NAME=sec_message:async_tasks
ASYNC_TASK_RETRY_QUEUE_NAME=
ASYNC_TASK_FAILED_QUEUE_NAME=
ASYNC_TASK_METRICS_KEY=
ASYNC_TASK_WORKER_REGISTRY_KEY=
ASYNC_TASK_WORKER_BLOCK_TIMEOUT_SECONDS=5
ASYNC_TASK_MAX_RETRIES=2
ASYNC_TASK_RETRY_BACKOFF_BASE_SECONDS=1.0
ASYNC_TASK_RETRY_BACKOFF_MAX_SECONDS=30.0
ASYNC_TASK_INLINE_FALLBACK=true
ASYNC_TASK_MIN_WORKER_COUNT=1
ASYNC_TASK_WORKER_HEARTBEAT_STALE_SECONDS=30
ASYNC_TASK_WORKER_STARTUP_STRICT=false
ASYNC_TASK_SKIP_STARTUP_WORKER_CHECK=false
ASYNC_TASK_ENQUEUE_SOCKET_TIMEOUT_SECONDS=0.75
ASYNC_TASK_ENQUEUE_CONNECT_TIMEOUT_SECONDS=0.75

# Activity post-engagement milestone notifications
ACTIVITY_MILESTONE_ENABLED=true
ACTIVITY_MILESTONE_ACTIVE_USERS_WINDOW_DAYS=7
ACTIVITY_MILESTONE_ACTIVE_USERS_CACHE_TTL_SECONDS=300
ACTIVITY_MILESTONE_LIKE_PERCENT=10
ACTIVITY_MILESTONE_COMMENT_PERCENT=5
ACTIVITY_MILESTONE_MIN_LIKES=5
ACTIVITY_MILESTONE_MIN_COMMENTERS=3

# Local HTTP cookies (for HTTPS production keep these as None/true)
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=false

# Messaging attachments
MESSAGE_ATTACHMENT_MAX_SIZE_BYTES=26214400

# Optional media/profile tuning
MEDIA_CACHE_MAX_AGE_SECONDS=604800
MEDIA_CACHE_IMMUTABLE=true
MEDIA_STREAM_CHUNK_SIZE=262144
# Security: inspect media headers and block active-content payloads masquerading as media.
MEDIA_CONTENT_SNIFFING_ENABLED=true
MEDIA_CONTENT_REJECT_ACTIVE_TEXT=true
MEDIA_CONTENT_ENFORCE_CATEGORY_MATCH=true
# Number of bytes read from the beginning of each file for signature checks.
MEDIA_CONTENT_SNIFF_BYTES=2048
PROFILE_VIDEO_MAX_DURATION_SECONDS=5
PROFILE_VIDEO_MAX_SIZE_BYTES=15728640

# Moderation cleanup worker
MODERATION_CLEANUP_BACKGROUND_ENABLED=true
MODERATION_CLEANUP_INTERVAL_SECONDS=300
